// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String
  password  String
  role      String     @default("user")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Lead {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String?
  whatsapp    String?
  source      String   // whatsapp, google_ads, meta_ads, instagram, website, referral, manual, other
  stage       String   @default("novo") // novo, em_atendimento, proposta_enviada, sem_resposta, finalizado
  handledBy   String   @default("manual") // ia, manual
  interest    String?  // expedição de interesse
  value       Float?   // valor estimado do negócio
  notes       String?
  lastMessage String?  // última mensagem recebida (WhatsApp)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Client {
  id         String    @id @default(cuid())
  name       String
  email      String?   @unique
  phone      String?
  whatsapp   String?
  cpfCnpj    String?
  address    String?
  city       String?
  state      String?
  birthDate  DateTime?
  bookings   Booking[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Expedition {
  id          String    @id @default(cuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  location    String
  maxPeople   Int
  pricePerPerson Float
  difficulty  String // fácil, intermediária, difícil
  images      String?  // JSON array of image URLs
  bookings    Booking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Booking {
  id         String    @id @default(cuid())
  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId   String
  expedition Expedition @relation(fields: [expeditionId], references: [id], onDelete: Cascade)
  expeditionId String
  quantity   Int
  totalPrice Float
  status     String    @default("pendente") // pendente, confirmada, cancelada
  paymentStatus String @default("aguardando") // aguardando, pagto_parcial, pago, cancelado
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  type      String   // hotel, restaurante, transporte, guia, etc
  email     String?
  phone     String?
  address   String?
  documents String?  // JSON: {cnpj, bankAccount, etc}
  rating    Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FinancialRecord {
  id          String   @id @default(cuid())
  type        String   // receita, despesa
  category    String   // vendas, fornecedores, operacional, etc
  description String
  amount      Float
  supplierId  String?  // se for despesa com fornecedor
  bookingId   String?  // se for receita de booking
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WhatsAppMessage {
  id        String   @id @default(cuid())
  leadId    String?
  clientId  String?
  message   String
  sender    String   // "user" ou "bot"
  createdAt DateTime @default(now())
}

// ── Flow Builder ──────────────────────────────────────────────────────────────

model Flow {
  id          String      @id @default(cuid())
  name        String
  description String?
  trigger     String      // "new_lead" | "keyword" | "manual"
  triggerData String?     // JSON: { "keyword": "rota café" }
  active      Boolean     @default(true)
  steps       FlowStep[]
  runs        FlowRun[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model FlowStep {
  id       String  @id @default(cuid())
  flow     Flow    @relation(fields: [flowId], references: [id], onDelete: Cascade)
  flowId   String
  order    Int
  type     String  // "text" | "delay" | "image" | "audio"
  content  String? // texto ou URL de mídia
  delayMin Int     @default(0)
}

model FlowRun {
  id        String        @id @default(cuid())
  flow      Flow          @relation(fields: [flowId], references: [id])
  flowId    String
  phone     String
  status    String        @default("running") // "running" | "completed" | "cancelled"
  messages  FlowMessage[]
  startedAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model FlowMessage {
  id          String    @id @default(cuid())
  run         FlowRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  runId       String
  stepOrder   Int
  type        String    // "text" | "image" | "audio"
  content     String?
  scheduledAt DateTime
  sentAt      DateTime?
  status      String    @default("pending") // "pending" | "sent" | "failed" | "cancelled"
  error       String?
  createdAt   DateTime  @default(now())
}

// ── Disparos em Massa ──────────────────────────────────────────────────────────

model Broadcast {
  id              String               @id @default(cuid())
  name            String
  message         String               // Template: {nome}, {telefone}
  mediaUrl        String?
  mediaType       String?              // "image" | "audio" | "video"
  status          String               @default("draft") // "draft" | "running" | "paused" | "completed" | "cancelled"
  recipientSource String               @default("custom") // "all_leads" | "all_clients" | "custom"
  intervalSec     Int                  @default(10)
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  recipients      BroadcastRecipient[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model BroadcastRecipient {
  id          String    @id @default(cuid())
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  broadcastId String
  phone       String
  name        String?
  status      String    @default("pending") // "pending" | "sent" | "failed" | "skipped"
  scheduledAt DateTime
  sentAt      DateTime?
  error       String?
  createdAt   DateTime  @default(now())
}
