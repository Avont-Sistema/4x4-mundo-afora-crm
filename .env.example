# --- Pagamentos ---
# Opção 1 (grátis, taxa zero): PIX copia-e-cola com a sua chave.
# Confirmação é manual no CRM. Funciona sem cadastro em nenhum provedor.
PIX_KEY=""                       # sua chave PIX (ex: CNPJ, email, telefone, aleatória)
PIX_MERCHANT_NAME="4x4 Mundo Afora"
PIX_MERCHANT_CITY="SAO PAULO"

# Opção 2 (recomendado p/ ticket alto): Asaas — PIX taxa fixa baixa,
# cartão à vista/parcelado, parcelamento no PIX e confirmação automática.
# Crie a conta e gere a chave em https://www.asaas.com (Integrações > API).
ASAAS_API_KEY=""
ASAAS_ENV="sandbox"              # sandbox | production
ASAAS_WEBHOOK_TOKEN=""           # opcional: valida o header asaas-access-token

# Instagram (para análise de leads)
INSTAGRAM_ACCESS_TOKEN=""

# Email (para disparo de leads)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
