# Canal: baileys (grátis, QR) ou meta (API oficial)
CHANNEL=baileys

# URL do CRM 4x4 (onde está o cérebro do agente)
CRM_URL=http://localhost:3030

# Token compartilhado entre conector e CRM (defina o MESMO no .env.local do CRM
# como WHATSAPP_CONNECTOR_TOKEN)
WHATSAPP_CONNECTOR_TOKEN=troque-este-token

# Porta do conector
PORT=8080

# --- Somente quando CHANNEL=meta (API oficial) ---
META_TOKEN=
META_PHONE_ID=
META_VERIFY_TOKEN=
